# ---- Supabase 設定 ----
# 1. 到 https://supabase.com 建立一個免費專案
# 2. 在專案的 Settings → API 找到下面這兩個值
# 3. 把這個檔案複製成 .env.local 並填入真實的值
#
# 注意：.env.local 不會被上傳到 git（已在 .gitignore 裡），請放心填入

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# ---- AI 鼓勵（選填）----
# mochi 的個人化鼓勵語會用 Anthropic API 生成。
# 到 https://console.anthropic.com 申請一把金鑰填在這裡。
# 留空也沒關係 —— 沒有金鑰時 mochi 會用內建的鼓勵語，App 一樣正常運作。
ANTHROPIC_API_KEY=
